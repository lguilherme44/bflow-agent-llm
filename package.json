{
  "name": "agent",
  "version": "1.0.0",
  "description": "Checkpointable ReAct coding agent core",
  "main": "dist/index.js",
  "bin": {
    "agent": "dist/cli.js",
    "vagent": "dist/visual-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "start": "node dist/index.js",
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx watch src/server.ts",
    "dev:agent": "tsx watch src/cli.ts",
    "agent": "npm run build && node dist/cli.js",
    "vagent": "npm run build && node dist/visual-cli.js",
    "agent:ollama": "npm run agent -- --provider=ollama",
    "agent:lmstudio": "npm run agent -- --provider=lmstudio",
    "vagent:ollama": "npm run vagent -- --provider=ollama",
    "vagent:lmstudio": "npm run vagent -- --provider=lmstudio",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "server": "npm run build && node dist/server.js",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "devDependencies": {
    "@types/lunr": "^2.3.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "apache-arrow": "^18.1.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lunr": "^2.3.9",
    "picocolors": "^1.1.1",
    "react": "^19.2.5",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-typescript": "^0.21.2",
    "ws": "^8.20.0"
  }
}
